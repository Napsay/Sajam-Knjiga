<Window x:Class="WpfClient.DodajPosetiocaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WpfClient.Resources"
        Title="{x:Static res:Strings.DodajPosetiocaWindow_Title}"
        Height="600" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

               
                <TextBlock Text="{x:Static res:Strings.Posetilac_BrClanskeKarte}" 
                           Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtBrClanskeKarte" Grid.Row="0" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Posetilac_Ime}" 
                           Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtIme" Grid.Row="1" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Posetilac_Prezime}" 
                           Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrezime" Grid.Row="2" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Autor_DatumRodjenja}" 
                           Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                <DatePicker x:Name="dpDatumRodjenja" Grid.Row="3" Grid.Column="1" Margin="5"/>

               
                <TextBlock Text="{x:Static res:Strings.Autor_KontaktTelefon}" 
                           Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtTelefon" Grid.Row="4" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Autor_Email}" 
                           Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtEmail" Grid.Row="5" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Posetilac_Status_Label}" 
                           Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbStatus" Grid.Row="6" Grid.Column="1" Margin="5">
                    <ComboBoxItem Content="{x:Static res:Strings.Status_Redovan}"/>
                    <ComboBoxItem Content="{x:Static res:Strings.Status_VIP}"/>
                </ComboBox>

                
                <TextBlock Text="{x:Static res:Strings.Posetilac_Adresa}" 
                           FontWeight="Bold"
                           Grid.Row="7" Grid.ColumnSpan="2" Margin="0,20,0,5"/>

                
                <TextBlock Text="{x:Static res:Strings.Adresa_Ulica}" 
                           Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtUlica" Grid.Row="8" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Adresa_Broj}" 
                           Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtBroj" Grid.Row="9" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Adresa_Grad}" 
                           Grid.Row="10" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtGrad" Grid.Row="10" Grid.Column="1" Margin="5"/>

                
                <TextBlock Text="{x:Static res:Strings.Adresa_Drzava}" 
                           Grid.Row="11" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDrzava" Grid.Row="11" Grid.Column="1" Margin="5"/>

                
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Grid.Row="12"
                            Grid.ColumnSpan="2"
                            Margin="0,25,0,0">

                    <Button Content="{x:Static res:Strings.Btn_Cancel}"
                            Width="100"
                            Margin="5"
                            Click="BtnOdustani_Click"/>

                    <Button x:Name="btnPotvrdi"
                            Content="{x:Static res:Strings.Btn_Confirm}"
                            Width="100"
                            Margin="5"
                            Background="#2196F3"
                            Foreground="White"
                            Click="BtnPotvrdi_Click"/>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Border>
</Window>