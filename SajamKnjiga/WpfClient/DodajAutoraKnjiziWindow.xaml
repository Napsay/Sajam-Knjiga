<Window x:Class="WpfClient.DodajAutoraKnjiziWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="Izaberi autora" Height="450" Width="800">
    <Border Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListBox x:Name="lstAutori"
                     Grid.Row="0"
                     DisplayMemberPath="PunoIme"
                     SelectionMode="Single"/>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="Odustani"
                        Width="100"
                        Margin="5"
                        Click="BtnOdustani_Click"/>
                <Button Content="Potvrdi"
                        Width="100"
                        Margin="5"
                        Background="#2196F3"
                        Foreground="White"
                        Click="BtnPotvrdi_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
