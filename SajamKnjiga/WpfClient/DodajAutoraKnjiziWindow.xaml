<Window x:Class="WpfClient.DodajAutoraKnjiziWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WpfClient.Resources"
        Title="{x:Static res:Strings.DodajAutoraKnjizi_Title}"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Border Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <ListBox x:Name="lstAutori"
                     Grid.Row="0"
                     DisplayMemberPath="PunoIme"
                     SelectionMode="Single"/>

            
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <Button Content="{x:Static res:Strings.Btn_Cancel}"
                        Width="100"
                        Margin="5"
                        Click="BtnOdustani_Click"/>

                <Button Content="{x:Static res:Strings.Btn_Confirm}"
                        Width="100"
                        Margin="5"
                        Background="#2196F3"
                        Foreground="White"
                        Click="BtnPotvrdi_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>