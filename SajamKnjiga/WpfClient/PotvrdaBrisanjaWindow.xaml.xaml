<Window x:Class="WpfClient.PotvrdaBrisanjaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Brisanje posetioca"
        Height="160"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="txtPoruka"
            Text="Da li ste sigurni da želite da obrišete posetioca?"
            FontSize="14"
            TextWrapping="Wrap"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            TextAlignment="Center"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Ne"
                    Width="80"
                    Margin="10,0"
                    Click="Ne_Click"/>

            <Button Content="Da"
        Width="80"
        Margin="10,0"
        Background="#2196F3"
        Foreground="White"
        FontWeight="Bold"
        Click="Da_Click"/>
        </StackPanel>
    </Grid>
</Window>

