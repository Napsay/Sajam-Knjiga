<Window x:Class="WpfClient.IzdavaciWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="Svi izdavaci" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="Prikaži knjige izdavača"
            Width="200"
            Margin="290,0,290,10"
            Click="BtnPrikaziKnjige_Click" Height="20" VerticalAlignment="Bottom"/>

        
        <DataGrid x:Name="dgIzdavaci"
              Grid.Row="1"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Šifra" Binding="{Binding Sifra}" Width="100"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid x:Name="dgKnjigeIzdavaca"
              Grid.Row="2"
              Margin="0,10,0,0"
              CanUserAddRows="False"
              AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="150"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                <DataGridTextColumn Header="Žanr" Binding="{Binding Zanr}" Width="120"/>
                <DataGridTextColumn Header="Godina" Binding="{Binding GodinaIzdanja}" Width="100"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding Cena}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
