<Window x:Class="WpfClient.IzborNovogEntitetaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        xmlns:res="clr-namespace:WpfClient.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.IzborNovogEntitetaWindow_Title}"
        Height="450" Width="800">

    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Center">

            <Button Content="{x:Static res:Strings.Izbor_NoviPosetilac}"
                    Margin="5"
                    Click="BtnPosetilac_Click"/>

            <Button Content="{x:Static res:Strings.Izbor_NoviAutor}"
                    Margin="5"
                    Click="BtnAutor_Click"/>

            <Button Content="{x:Static res:Strings.Izbor_NovaKnjiga}"
                    Margin="5"
                    Click="BtnKnjiga_Click"/>

            <Button Content="{x:Static res:Strings.Btn_Cancel}"
                    Margin="5"
                    Background="LightGray"
                    Foreground="Black"
                    Click="BtnOdustani_Click"
                    Width="750"/>

        </StackPanel>
    </Grid>
</Window>