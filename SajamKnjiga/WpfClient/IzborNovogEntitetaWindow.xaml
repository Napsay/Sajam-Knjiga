<Window x:Class="WpfClient.IzborNovogEntitetaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="IzborNovogEntitetaWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Center">

            <Button Content="Novi posetilac"
                Margin="5"
                Click="BtnPosetilac_Click"/>

            <Button Content="Novi autor"
                Margin="5"
                Click="BtnAutor_Click"/>

            <Button Content="Nova knjiga"
                Margin="5"
                Click="BtnKnjiga_Click"/>
            
            <Button Content="Odustani"
            Margin="5"
             Background="LightGray"
             Foreground="Black"       
            Click="BtnOdustani_Click" Width="750"/>

        </StackPanel>
    </Grid>
</Window>
