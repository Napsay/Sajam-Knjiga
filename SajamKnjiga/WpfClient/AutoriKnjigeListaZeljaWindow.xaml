<Window x:Class="WpfClient.AutoriKnjigeListaZeljaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="Autori sa knjigama na listi želja" Height="450" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
            <TextBox x:Name="txtPretraga"
                     Width="200"
                     Height="24"
                     VerticalContentAlignment="Center"
                     Margin="0,0,5,0"/>
            <Button Width="30" Height="24" Click="Pretrazi_Click">🔍</Button>
        </StackPanel>

        <DataGrid x:Name="dgAutori" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="150"/>
                <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="150"/>
                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Width="80" Height="30" Click="Close_Click">Zatvori</Button>
        </StackPanel>
    </Grid>
</Window>