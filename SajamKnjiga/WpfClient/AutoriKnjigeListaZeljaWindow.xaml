<Window x:Class="WpfClient.AutoriKnjigeListaZeljaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WpfClient.Resources"
        Title="{x:Static res:Strings.AutoriListaZelja_Title}"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,0,10">

            <TextBlock Text="{x:Static res:Strings.AutoriListaZelja_Search}"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <TextBox x:Name="txtPretraga"
                     Width="200"
                     Height="24"
                     VerticalContentAlignment="Center"
                     Margin="0,0,5,0"/>

            <Button Width="30"
                    Height="24"
                    Click="Pretrazi_Click"
                    Content="{x:Static res:Strings.Btn_Search}"/>
        </StackPanel>

        
        <DataGrid x:Name="dgAutori"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Ime}"
                                    Binding="{Binding Ime}"
                                    Width="150"/>

                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Prezime}"
                                    Binding="{Binding Prezime}"
                                    Width="150"/>

                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Email}"
                                    Binding="{Binding Email}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Width="100"
                    Height="30"
                    Click="Close_Click"
                    Content="{x:Static res:Strings.AutoriListaZelja_Close}"/>
        </StackPanel>

    </Grid>
</Window>