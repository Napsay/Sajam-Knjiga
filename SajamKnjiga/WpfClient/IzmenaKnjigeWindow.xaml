<Window x:Class="WpfClient.IzmenaKnjigeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Izmena knjige"
        Height="600" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Padding="15">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FORMA -->
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ISBN *" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtISBN" Grid.Row="0" Grid.Column="1" Margin="5" IsReadOnly="True"/>

                <TextBlock Text="Naziv *" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtNaziv" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Žanr *" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtZanr" Grid.Row="2" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Godina izdanja *" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtGodina" Grid.Row="3" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Cena *" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtCena" Grid.Row="4" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Broj strana *" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtStrana" Grid.Row="5" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Izdavač *" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbIzdavac"
                          Grid.Row="6"
                          Grid.Column="1"
                          Margin="5"
                          DisplayMemberPath="Naziv"/>

                <TextBlock Text="Autori *"
                           Grid.Row="7"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Margin="0,10,0,0"/>

                <ListBox x:Name="lstAutori"
                         Grid.Row="7"
                         Grid.Column="1"
                         Margin="5"
                         SelectionMode="Multiple"
                         DisplayMemberPath="PunoIme"/>
            </Grid>

            <!-- DUGMAD -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">

                <Button Content="Odustani"
                        Width="110"
                        Margin="5"
                        Click="BtnOdustani_Click"/>

                <Button x:Name="btnPotvrdi"
                        Content="Potvrdi"
                        Width="110"
                        Margin="5"
                        Click="BtnPotvrdi_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
