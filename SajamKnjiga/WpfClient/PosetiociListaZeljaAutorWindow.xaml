<Window x:Class="WpfClient.PosetiociListaZeljaAutorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="" Height="450" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
            <TextBox x:Name="txtPretraga"
                     Width="200"
                     Height="24"
                     VerticalContentAlignment="Center"
                     Margin="0,0,5,0"/>
            <Button Width="30" Height="24" Click="Pretrazi_Click">🔍</Button>
        </StackPanel>

        <DataGrid x:Name="dgPosetioci" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="Posetilac_ClanskaKarta" Header="Broj članske karte"
                                    Binding="{Binding BrClanskeKarte}"
                                    Width="150"/>
                <DataGridTextColumn x:Name="Posetilac_Ime" Header="Ime"
                                    Binding="{Binding Ime}"
                                    Width="100"/>
                <DataGridTextColumn x:Name="Posetilac_Prezime" Header="Prezime"
                                    Binding="{Binding Prezime}"
                                    Width="120"/>
                <DataGridTextColumn x:Name="Posetilac_Adresa" Header="Adresa"
                                    Binding="{Binding Adresa}"
                                    Width="*"/>
                <DataGridTextColumn x:Name="Posetilac_Status" Header="Status"
                                    Binding="{Binding Status}"
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="Btn_Close" Width="80" Height="30" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
