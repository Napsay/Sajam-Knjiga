<Window x:Class="WpfClient.AnalitikaIzdavaca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="AnalitikaIzdavaca" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Prikaži knjige izdavača"
              Width="200"
              Margin="0,0,10,0"
              Click="BtnPrikaziKnjige_Click"/>

            <Button Content="Prikaži autore izdavača"
              Width="200"
              Click="BtnPrikaziAutore_Click"/>
        </StackPanel>


        <DataGrid x:Name="dgIzdavaci"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            SelectionMode="Single"
               IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Šifra" Binding="{Binding Sifra}" Width="100"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>


        <DataGrid x:Name="dgKnjigeIzdavaca"
            Grid.Row="2"
            Margin="0,10,0,0"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="150"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>


        <DataGrid x:Name="dgAutoriIzdavaca"
            Grid.Row="3"
            Margin="0,10,0,0"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="120"/>
                <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="140"/>
                <DataGridTextColumn Header="Datum rođenja" Binding="{Binding DatumRodjenja, StringFormat=dd.MM.yyyy}" Width="130"/>
                <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa}" Width="*"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
