<Window x:Class="WpfClient.AnalitikaIzdavaca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WpfClient.Resources"
        Title="{x:Static res:Strings.AnalitikaIzdavaci_Title}"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <TextBlock Grid.Row="0"
                   Text="{x:Static res:Strings.AnalitikaIzdavaci_Svi}"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,0,0,5"/>

        <!-- Izdavači -->
        <DataGrid x:Name="dgIzdavaci"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static res:Strings.Kolona_Sifra}"
                                    Binding="{Binding Sifra}"
                                    Width="100"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Kolona_Naziv}"
                                    Binding="{Binding Naziv}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dugme knjige -->
        <Button Grid.Row="2"
                Content="{x:Static res:Strings.AnalitikaIzdavaci_PrkaziKnjige}"
                Width="220"
                Margin="0,5,0,5"
                HorizontalAlignment="Left"
                Click="BtnPrikaziKnjige_Click"/>

        <!-- Knjige izdavača -->
        <DataGrid x:Name="dgKnjigeIzdavaca"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static res:Strings.Knjiga_ISBN}"
                                    Binding="{Binding ISBN}"
                                    Width="150"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Knjiga_Naziv}"
                                    Binding="{Binding Naziv}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dugme autori -->
        <Button Grid.Row="4"
                Content="{x:Static res:Strings.AnalitikaIzdavaci_PrkaziAutore}"
                Width="220"
                Margin="0,5,0,5"
                HorizontalAlignment="Left"
                Click="BtnPrikaziAutore_Click"/>

        <!-- Autori izdavača -->
        <DataGrid x:Name="dgAutoriIzdavaca"
                  Grid.Row="5"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Ime}"
                                    Binding="{Binding Ime}"
                                    Width="120"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Prezime}"
                                    Binding="{Binding Prezime}"
                                    Width="140"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_DatumRodjenja}"
                                    Binding="{Binding DatumRodjenja, StringFormat=dd.MM.yyyy}"
                                    Width="130"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Adresa}"
                                    Binding="{Binding Adresa}"
                                    Width="*"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Telefon}"
                                    Binding="{Binding Telefon}"
                                    Width="120"/>
                <DataGridTextColumn Header="{x:Static res:Strings.Autor_Email}"
                                    Binding="{Binding Email}"
                                    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>