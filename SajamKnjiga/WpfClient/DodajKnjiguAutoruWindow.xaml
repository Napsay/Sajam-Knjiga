<Window x:Class="WpfClient.DodajKnjiguAutoruWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="Dodaj Knjigu" Height="450" Width="800">
    <Border Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock
                Text="Изаберите књигу (или више књига) које желите да додате аутору:"
                FontWeight="SemiBold"
                Margin="0,0,0,10"/>

            <ListBox x:Name="lstKnjige"
         Grid.Row="1"
         SelectionMode="Extended"
         SelectionChanged="lstKnjige_SelectionChanged">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="Knjiga_ISBN" Grid.Column="0"
                           Text="{Binding ISBN}"
                           FontWeight="SemiBold"/>

                            <TextBlock x:Name="Knjiga_Naziv" Grid.Column="1"
                           Text="{Binding Naziv}"
                           Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">

                <Button Content="Одустани"
                        Width="110"
                        Margin="5"
                        Click="BtnOdustani_Click"/>

                <Button x:Name="btnPotvrdi"
                        Content="Потврди"
                        Width="110"
                        Margin="5"
                        IsEnabled="False"
                        Background="#2196F3"
                        Foreground="White"
                        Click="BtnPotvrdi_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
