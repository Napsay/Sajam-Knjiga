<Window x:Class="WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- MENU BAR -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New"/>
                <MenuItem Header="_Save"/>
                <Separator/>
                <MenuItem Header="_Open">
                    <MenuItem Header="Posetioci"/>
                    <MenuItem Header="Knjige"/>
                    <MenuItem Header="Autori"/>
                    <MenuItem Header="Izdavači"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Close"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Edit"/>
                <MenuItem Header="_Delete"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About"/>
            </MenuItem>
        </Menu>

        <!-- TOOLBAR -->
        <ToolBarTray Grid.Row="1">
            <ToolBar>
                <Button ToolTip="Dodaj novi entitet">➕</Button>
                <Button ToolTip="Izmeni selektovani entitet">✏️</Button>
                <Button ToolTip="Obriši selektovani entitet">🗑️</Button>
                <Separator/>
                <TextBox Width="150" Margin="5,0"/>
                <Button ToolTip="Pretraga">🔍</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- CENTRALNI TABOVI -->
        <TabControl Grid.Row="2" Margin="5">

            <TabItem Header="Posetioci">
                <DataGrid AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Broj kartice" Binding="{Binding BrojKartice}"/>
                        <DataGridTextColumn Header="Ime" Binding="{Binding Ime}"/>
                        <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}"/>
                        <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Autori">
                <DataGrid AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ime" Binding="{Binding Ime}"/>
                        <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}"/>
                        <DataGridTextColumn Header="Broj lične karte" Binding="{Binding BrojLicneKarte}"/>
                        <DataGridTextColumn Header="Datum rođenja" Binding="{Binding DatumRodjenja}"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Knjige">
                <DataGrid AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}"/>
                        <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}"/>
                        <DataGridTextColumn Header="Cena" Binding="{Binding Cena}"/>
                        <DataGridTextColumn Header="Godina" Binding="{Binding GodinaIzdanja}"/>
                        <DataGridTextColumn Header="Žanr" Binding="{Binding Zanr}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <!-- STATUS BAR -->
        <StatusBar Grid.Row="3">
            <StatusBarItem Content="Sajam knjiga"/>
            <Separator/>
            <StatusBarItem Content="{Binding TrenutniTab}"/>
            <Separator/>
            <StatusBarItem Content="{Binding TrenutniDatum}"/>
            <StatusBarItem Content="{Binding TrenutnoVreme}"/>
        </StatusBar>
    </Grid>
</Window>
