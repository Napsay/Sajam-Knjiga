<Window x:Class="WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sajam knjiga" Height="600" Width="1000">
    <Window.InputBindings>
        <KeyBinding Key="N"
                Modifiers="Control"
                Command="ApplicationCommands.New"/>
        <KeyBinding Key="Delete"
            Command="ApplicationCommands.Delete"/>
        <KeyBinding Key="E"
            Modifiers="Control"
            Command="NavigationCommands.Refresh"/>
        
    </Window.InputBindings>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="40"/>
            
            <RowDefinition Height="*"/>
            
            <RowDefinition Height="Auto"/>
            
        </Grid.RowDefinitions>

        
        <Menu Grid.Row="0">
            <MenuItem Header="_File" Click="MenuItem_Click_1">
                <MenuItem Header="_New" Click="New_Click" InputGestureText="CTRL+N"/>
                
                <Separator/>
                <MenuItem Header="_Open">
                    <MenuItem Header="Posetioci" Click="OpenPosetioci_Click"/>
                    <MenuItem Header="Knjige" Click="OpenKnjige_Click"/>
                    <MenuItem Header="Autori" Click="OpenAutori_Click"/>
                    <MenuItem Header="Izdavači" Click="OpenIzdavaci_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Save" Click="Save_Click"/>
                <MenuItem Header="_Close" Click="CloseApp_Click" />
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Edit"
                          Click="Button_Click_1"
                          InputGestureText="CTRL+E"/>
                <MenuItem Header="_Delete"
                          Click="ObrisiEntitet_Click"
                          InputGestureText="Del"/>
            </MenuItem>

            <MenuItem Header="_Analitika">
                <MenuItem Header="Analitika za dve knjige"
              Click="OpenAnalitika_Click"/>

                <MenuItem Header="Analitika izdavača"
              Click="OpenAnalitikaIzdavaca_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About"
                          Click="About_Click"/>
            </MenuItem>
        </Menu>

        
        <Border Grid.Row="1" Background="#EEEEEE" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Grid Margin="5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="30" Margin="2" Click="DodajEntitet_Click">➕</Button>
                    <Button Width="30" Margin="2" Click="Button_Click_1">✏️</Button>
                    <Button Width="30" Margin="2" Click="ObrisiEntitet_Click">🗑️</Button>
                </StackPanel>

               
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBox x:Name="txtPretraga"
                             Width="180" Height="24"
                             VerticalContentAlignment="Center"
                             Margin="0,0,5,0"/>
                    <Button Width="30" Click="Pretrazi_Click">🔍</Button>
                </StackPanel>
            </Grid>
        </Border>


        <TabControl x:Name="MainTabControl"
            Grid.Row="2"
            Margin="5"
            SelectionChanged="TabControl_SelectionChanged">

              <TabItem Header="Posetioci">
                <StackPanel Orientation="Vertical" Margin="5">
                    <Button Content="Prikazi autore knjiga na listi želja posetioca"
                            Width="250"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,5"
                            Click="BtnPrikaziAutore_Click"/>
                    <DataGrid x:Name="dgPosetioci"
                  AutoGenerateColumns="False"
                  Margin="5"
                  RowBackground="White"
                  AlternatingRowBackground="#F0F0F0"
                  GridLinesVisibility="None"
                  CanUserAddRows="False"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeight="25" 
                  Sorting="dgPosetioci_Sorting">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#D3D3D3"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Broj članske karte"
                                    Binding="{Binding BrClanskeKarte}"
                                    Width="150"/>
                            <DataGridTextColumn Header="Ime"
                                    Binding="{Binding Ime}"
                                    Width="100"/>
                            <DataGridTextColumn Header="Prezime"
                                    Binding="{Binding Prezime}"
                                    Width="120"/>
                            <DataGridTextColumn Header="Adresa"
                                    Binding="{Binding Adresa}"
                                    Width="*"/>
                            <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="100"/>
                            <DataGridTextColumn Header="Godina članstva" 
                                     Binding="{Binding GodineClanstvaPrikaz}" />
                            <DataGridTextColumn Header="Prosečna ocena" 
                                     Binding="{Binding ProsecnaOcenaRec, StringFormat=F1}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <Button Name="btnFirstPagePosetioci" Tag="Posetioci" Click="BtnFirstPage_Click" Content="&lt; Prva" Margin="5"/>
                        <Button Name="btnPrevPagePosetioci" Tag="Posetioci" Click="BtnPrevPage_Click" Content="&lt;&lt;" Margin="5"/>
                        <TextBlock Name="txtPosetiociPageInfo" VerticalAlignment="Center" Margin="5"/>
                        <Button Name="btnNextPagePosetioci" Tag="Posetioci" Click="BtnNextPage_Click" Content="&gt;&gt;" Margin="5"/>
                        <Button Name="btnLastPagePosetioci" Tag="Posetioci" Click="BtnLastPage_Click" Content="Poslednja &gt;" Margin="5"/>
                    </StackPanel>

                </StackPanel>
            </TabItem>

            <TabItem Header="Autori">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Content="Prikaži posetioce sa knjigama autora na listi želja"
                Width="300"
                HorizontalAlignment="Left"
                Margin="0,0,0,5"
                Click="BtnPrikaziPosetioce_Click"
                Grid.Row="0"/>

                    <DataGrid x:Name="dgAutori"
                  AutoGenerateColumns="False"
                  Margin="5"
                  RowBackground="White"
                  AlternatingRowBackground="#F0F0F0"
                  GridLinesVisibility="None"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeight="25"
                  CanUserSortColumns="True"
                  Sorting="dgAutori_Sorting"
                  Grid.Row="1">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#D3D3D3"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                            Binding="{Binding AutorID}"
                            Width="60"/>
                            <DataGridTextColumn Header="Ime"
                            Binding="{Binding Ime}"
                            Width="120"/>
                            <DataGridTextColumn Header="Prezime"
                            Binding="{Binding Prezime}"
                            Width="140"/>
                            <DataGridTextColumn Header="Datum rođenja"
                            Binding="{Binding DatumRodjenja, StringFormat=dd.MM.yyyy}"
                            Width="130"/>
                            <DataGridTextColumn Header="Adresa"
                            Binding="{Binding Adresa}"
                            Width="*"/>
                            <DataGridTextColumn Header="Telefon"
                            Binding="{Binding Telefon}"
                            Width="120"/>
                            <DataGridTextColumn Header="Email"
                            Binding="{Binding Email}"
                            Width="160"/>
                            <DataGridTextColumn Header="God. iskustva"
                            Binding="{Binding GodineIskustva}"
                            Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" Grid.Row="2">
                        <Button Name="btnFirstPageAutori" Tag="Autori" Click="BtnFirstPage_Click" Content="&lt; Prva" Margin="5"/>
                        <Button Name="btnPrevPageAutori" Tag="Autori" Click="BtnPrevPage_Click" Content="&lt;&lt;" Margin="5"/>
                        <TextBlock Name="txtAutoriPageInfo" VerticalAlignment="Center" Margin="5"/>
                        <Button Name="btnNextPageAutori" Tag="Autori" Click="BtnNextPage_Click" Content="&gt;&gt;" Margin="5"/>
                        <Button Name="btnLastPageAutori" Tag="Autori" Click="BtnLastPage_Click" Content="Poslednja &gt;" Margin="5"/>
                    </StackPanel>
                </Grid>
            </TabItem>


            <TabItem Header="Knjige">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgKnjige"
                  AutoGenerateColumns="False"
                  Margin="5"
                  RowBackground="White"
                  AlternatingRowBackground="#F0F0F0"
                  GridLinesVisibility="None"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeight="25"
                  CanUserSortColumns="True"
                  Sorting="dgKnjige_Sorting"
                  Grid.Row="0">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#D3D3D3"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="140"/>
                            <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                            <DataGridTextColumn Header="Žanr" Binding="{Binding Zanr}" Width="120"/>
                            <DataGridTextColumn Header="Godina" Binding="{Binding GodinaIzdanja}" Width="80"/>
                            <DataGridTextColumn Header="Cena" Binding="{Binding Cena}" Width="80"/>
                            <DataGridTextColumn Header="Strana" Binding="{Binding BrojStrana}" Width="80"/>
                            <DataGridTextColumn Header="Izdavač" Binding="{Binding Izdavac.Naziv}" Width="160"/>
                            <DataGridTextColumn Header="Autori" Binding="{Binding AutoriPrikaz}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" Grid.Row="1">
                        <Button Name="btnFirstPageKnjige" Tag="Knjige" Click="BtnFirstPage_Click" Content="&lt; Prva" Margin="5"/>
                        <Button Name="btnPrevPageKnjige" Tag="Knjige" Click="BtnPrevPage_Click" Content="&lt;&lt;" Margin="5"/>
                        <TextBlock Name="txtKnjigePageInfo" VerticalAlignment="Center" Margin="5"/>
                        <Button Name="btnNextPageKnjige" Tag="Knjige" Click="BtnNextPage_Click" Content="&gt;&gt;" Margin="5"/>
                        <Button Name="btnLastPageKnjige" Tag="Knjige" Click="BtnLastPage_Click" Content="Poslednja &gt;" Margin="5"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="txtStatusLevo"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtDateTime"/>
            </StatusBarItem>
        </StatusBar>


    </Grid>
</Window>
