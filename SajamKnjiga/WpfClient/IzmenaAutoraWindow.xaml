<Window x:Class="WpfClient.IzmenaAutoraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WpfClient.Resources"
        Title="{x:Static res:Strings.IzmenaAutoraWindow_Title}"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Padding="15">
        <Grid>
            <TabControl>

                <TabItem Header="{x:Static res:Strings.Tab_Informacije}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.Autor_Ime}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtIme" Grid.Row="0" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_Prezime}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtPrezime" Grid.Row="1" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_DatumRodjenja}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                                <DatePicker x:Name="dpDatumRodjenja" Grid.Row="2" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_KontaktTelefon}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtTelefon" Grid.Row="3" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_Email}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtEmail" Grid.Row="4" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_BrLicne}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtBrLicne" Grid.Row="5" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_GodIskustva}" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtGodineIskustva" Grid.Row="6" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Autor_Adresa_Label}" 
                                           FontWeight="Bold" Grid.Row="7" Grid.ColumnSpan="2" Margin="0,15,0,5"/>

                                <TextBlock Text="{x:Static res:Strings.Adresa_Ulica}" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtUlica" Grid.Row="8" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Adresa_Broj}" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtBroj" Grid.Row="9" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Adresa_Grad}" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtGrad" Grid.Row="10" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="{x:Static res:Strings.Adresa_Drzava}" Grid.Row="11" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtDrzava" Grid.Row="11" Grid.Column="1" Margin="5"/>
                            </Grid>
                        </ScrollViewer>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="{x:Static res:Strings.Btn_Cancel}" Width="110" Margin="5" Click="BtnOdustani_Click"/>
                            <Button x:Name="btnPotvrdi" Content="{x:Static res:Strings.Btn_Confirm}" Width="110" Margin="5" Background="#2196F3" Foreground="White" Click="BtnPotvrdi_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="{x:Static res:Strings.Tab_Knjige}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="{x:Static res:Strings.Btn_AddBook}" Width="120" Margin="5" Click="BtnDodajKnjigu_Click"/>
                            <Button Content="{x:Static res:Strings.Btn_RemoveBook}" Width="120" Margin="5" Click="BtnUkloniKnjigu_Click"/>
                        </StackPanel>

                        <DataGrid x:Name="dgKnjige" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static res:Strings.Knjiga_ISBN}" Binding="{Binding ISBN}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static res:Strings.Knjiga_Naziv}" Binding="{Binding Naziv}" Width="2*"/>
                                <DataGridTextColumn Header="{x:Static res:Strings.Knjiga_GodIzdavanja}" Binding="{Binding GodinaIzdanja}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static res:Strings.Knjiga_Zanr}" Binding="{Binding Zanr}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</Window>