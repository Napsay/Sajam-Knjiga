<Window x:Class="WpfClient.DodajKnjiguWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WpfClient.Resources"
        Title="{x:Static res:Strings.DodajKnjiguWindow_Title}"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Padding="20">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_ISBN}" Grid.Row="0"/>
            <TextBox x:Name="txtISBN" Grid.Row="0" Grid.Column="1" Margin="5"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_Naziv}" Grid.Row="1"/>
            <TextBox x:Name="txtNaziv" Grid.Row="1" Grid.Column="1" Margin="5"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_Zanr}" Grid.Row="2"/>
            <TextBox x:Name="txtZanr" Grid.Row="2" Grid.Column="1" Margin="5"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_Godina}" Grid.Row="3"/>
            <TextBox x:Name="txtGodina" Grid.Row="3" Grid.Column="1" Margin="5"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_Cena}" Grid.Row="4"/>
            <TextBox x:Name="txtCena" Grid.Row="4" Grid.Column="1" Margin="5"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_BrojStrana}" Grid.Row="5"/>
            <TextBox x:Name="txtStrana" Grid.Row="5" Grid.Column="1" Margin="5"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_Izdavac}" Grid.Row="6"/>
            <ComboBox x:Name="cmbIzdavac" Grid.Row="6" Grid.Column="1" Margin="5"
                      DisplayMemberPath="Naziv"/>

            <TextBlock Text="{x:Static res:Strings.DodajKnjigu_Autori}" 
                       Grid.Row="7" VerticalAlignment="Top"/>
            <ListBox x:Name="lstAutori" Grid.Row="7" Grid.Column="1" Margin="5"
                     Height="100" SelectionMode="Multiple"
                     DisplayMemberPath="Ime"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Grid.Row="10"
                        Grid.ColumnSpan="2"
                        Margin="0,30,0,0">

                <Button Content="{x:Static res:Strings.Btn_Cancel}"
                        Width="110"
                        Margin="0,0,15,0"
                        Click="BtnOdustani_Click"/>

                <Button x:Name="btnPotvrdi"
                        Content="{x:Static res:Strings.Btn_Confirm}"
                        Width="110"
                        Background="#2196F3"
                        Foreground="White"
                        Click="BtnPotvrdi_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>