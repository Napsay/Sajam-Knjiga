<Window x:Class="WpfClient.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        xmlns:res="clr-namespace:WpfClient.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.About_Title}"
        Height="450" Width="800">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                
                <TextBlock Text="{x:Static res:Strings.About_AppName}"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                
                <TextBlock x:Name="txtVersion"
                           Margin="0,10,0,10"
                           HorizontalAlignment="Center"/>

               
                <TextBlock Text="{x:Static res:Strings.About_Description}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                
                <TextBlock Text="{x:Static res:Strings.About_Authors}"
                           FontWeight="Bold"
                           Margin="0,10,0,5"/>

                
                <TextBlock Text="{x:Static res:Strings.About_Authors_Text}"
                           TextWrapping="Wrap"
                           Margin="0,5,0,10"/>

                
                <Button Content="{x:Static res:Strings.About_Close}"
                        Width="100"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Click="Button_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>